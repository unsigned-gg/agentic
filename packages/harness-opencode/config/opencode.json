{
  "$schema": "https://opencode.ai/config.json",
  "model": "llm/google/gemini-3.5-flash",
  "provider": {
    "llm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llm (unsigned model gateway)",
      "options": {
        "baseURL": "https://llm.unsigned.gg/v1"
      },
      "models": {
        "zai/GLM-5.2": {
          "name": "GLM-5.2 (Crusoe, hosted)"
        },
        "deepseek-ai/DeepSeek-V4-Pro": {
          "name": "DeepSeek-V4-Pro (Crusoe)"
        },
        "Qwen/Qwen3-235B-A22B-Instruct-2507": {
          "name": "Qwen3-235B (Crusoe)"
        },
        "moonshotai/Kimi-K2.6": {
          "name": "Kimi-K2.6 (Crusoe)"
        },
        "openai/gpt-5.5": {
          "name": "GPT-5.5 (OpenRouter)"
        },
        "google/gemini-3.5-flash": {
          "name": "Gemini 3.5 Flash (OpenRouter)"
        },
        "moonshotai/kimi-k2.7-code": {
          "name": "Kimi K2.7 Code (OpenRouter)"
        },
        "mistralai/devstral-2512": {
          "name": "Devstral 2512 (OpenRouter)"
        },
        "claude-sonnet-5": {
          "name": "Claude Sonnet 5 (Anthropic, direct)"
        },
        "claude-haiku-4-5": {
          "name": "Claude Haiku 4.5 (Anthropic, direct)"
        },
        "claude-opus-4-8": {
          "name": "Claude Opus 4.8 (Anthropic, direct)"
        },
        "morph-v3-fast": {
          "name": "Morph v3 Fast (fast-apply)"
        },
        "morph-glm52-744b": {
          "name": "Morph GLM-5.2 744B"
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3.6-27b-mtp": {
          "name": "Qwen 3.6 27B MTP (verified agentic)"
        },
        "qwen3.5-9b-mtp": {
          "name": "Qwen 3.5 9B MTP (verified agentic)"
        },
        "gemma4:latest": {
          "name": "Gemma 4 E4B (verified agentic)"
        },
        "qwen3.6-35b-mtp": {
          "name": "Qwen 3.6 35B-A3B MTP (pre-warm first)"
        },
        "hf.co/unsloth/Devstral-Small-2-24B-Instruct-2512-GGUF:UD-Q4_K_XL": {
          "name": "Devstral Small 2 24B"
        }
      }
    },
    "llamacpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp server (local)",
      "options": {
        "baseURL": "http://localhost:8080/v1"
      },
      "models": {
        "local": {
          "name": "llama.cpp served model"
        }
      }
    },
    "vllm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "vLLM (local)",
      "options": {
        "baseURL": "http://localhost:8000/v1"
      },
      "models": {
        "served-model": {
          "name": "vLLM served model"
        }
      }
    }
  }
}
